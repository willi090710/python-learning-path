print("--cloud-service monitoring tool--")

server_id=input("What server do you want to test (1-5): ")

if server_id=="Server 1" or server_id=="Server 2":
    print(f"✅ {server_id} Status: Online / Healthy")
elif server_id=="Server 3":
    print(f"⚠️ {server_id} Status: Warning / High Latency")
elif server_id=="Server 4":
    print(f"❌ {server_id} Status: Offline / Critical Error")
elif server_id=="Server 5":
    print(f"⚠️ {server_id} Status: Maintenance")
else:
    print(f"❓{server_id} Status: Unknown Server-ID")
